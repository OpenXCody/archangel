# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/archangel?sslmode=require

# MapTiler (free tier: https://cloud.maptiler.com/account/keys)
VITE_MAPTILER_API_KEY=your_maptiler_key_here

# Server
PORT=3000
NODE_ENV=development

# Client (optional, defaults to /api)
VITE_API_URL=http://localhost:3000/api
